---
export interface Props {
  title: string;
}

const { title } = Astro.props;
import Navbar from "../components/Navbar.astro";
import "@fontsource/geist/400.css";
import "@fontsource/geist/500.css";
import "@fontsource/geist/600.css";
import "@fontsource/geist/700.css";
import "../styles/global.css";
import { sitePath } from "../lib/site-path";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="William Carter Portfolio Homepage" />
    <meta name="author" content="William Carter" />
    <meta property="og:image" content={sitePath("/thumbnail.webp")} />
    <link rel="icon" type="image/svg+xml" href={sitePath("/favicon.svg")} />
<meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
          return localStorage.getItem("theme");
        }
        return "dark";
      })();

      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
      window.localStorage.setItem("theme", theme);
      let currentTheme = localStorage.getItem("theme");
      if (currentTheme != null) {
        document.documentElement.setAttribute("data-theme", currentTheme);
        localStorage.setItem("theme", currentTheme);
      }
    </script>
    <script is:inline>
      (function () {
        var navbar = null;
        function update() {
          if (!navbar) navbar = document.querySelector('.site-navbar');
          if (!navbar) return;
          if (window.scrollY > 200) {
            navbar.setAttribute('data-scrolled', '');
          } else {
            navbar.removeAttribute('data-scrolled');
          }
        }
        window.addEventListener('scroll', update, { passive: true });
        document.addEventListener('DOMContentLoaded', update);
      })();
    </script>
  </head>

  <body class="bg-offw dark:bg-dark">
    <svg width="0" height="0" style="position:absolute;pointer-events:none;" aria-hidden="true">
      <defs>
        <filter id="navbar-glass-distortion" x="0%" y="0%" width="100%" height="100%">
          <feTurbulence type="fractalNoise" baseFrequency="0.025 0.025" numOctaves="2" seed="42" result="noise" />
          <feGaussianBlur in="noise" stdDeviation="1.5" result="blurred" />
          <feDisplacementMap in="SourceGraphic" in2="blurred" scale="12" xChannelSelector="R" yChannelSelector="G" />
        </filter>
      </defs>
    </svg>
    <div class="site-header">
      <Navbar />
    </div>
    <slot />
  </body>
</html>

<style>
  :global(.site-header) {
    position: fixed;
    inset: 0 0 auto;
    z-index: 10;
  }

  :global(.site-navbar) {
    width: 100%;
    margin-inline: auto;
    background-color: rgb(255 255 255 / 38%);
    backdrop-filter: blur(4px);
    position: relative;
    isolation: isolate;
    transition: backdrop-filter 0.35s ease;
  }

  :global(.dark .site-navbar) {
    background-color: rgb(32 32 35 / 50%);
  }

  /* Rim light — fades in with glass effect */
  :global(.site-navbar::before) {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    box-shadow: inset 0 0 14px -4px rgba(255, 255, 255, 0.55);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  /* Backdrop blur + distortion layer — fades in with glass effect */
  :global(.site-navbar::after) {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    filter: url(#navbar-glass-distortion);
    -webkit-filter: url(#navbar-glass-distortion);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  @media (min-width: 700px) and (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: scroll()) {
      :global(.site-navbar) {
        animation: compact-navbar linear both;
        animation-timeline: scroll(root block);
        animation-range: 0 240px;
      }

      :global(.site-navbar[data-scrolled]) {
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
      }

      :global(.site-navbar[data-scrolled]::before),
      :global(.site-navbar[data-scrolled]::after) {
        opacity: 1;
      }

      :global(.site-navbar .navlinks) {
        animation: compact-navlinks linear both;
        animation-timeline: scroll(root block);
        animation-range: 0 240px;
      }
    }
  }

  @keyframes compact-navlinks {
    from { gap: 2rem; }
    to { gap: 1rem; }
  }

  @keyframes compact-navbar {
    from {
      width: 100%;
      margin-top: 0;
      border-radius: 0;
      box-shadow: none;
    }

    to {
      width: min(90vw, 56rem);
      margin-top: 1rem;
      border-radius: 0.75rem;
      box-shadow:
        0 0.65rem 1.5rem rgb(0 0 0 / 12%),
        0 0.15rem 0.45rem rgb(0 0 0 / 8%),
        0 0 20px -6px rgba(255, 255, 255, 0.2);
    }
  }

  h3 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    text-align: center;
  }

  @media only screen and (max-width: 700px) {
    h3 {
      font-size: 1.5rem;
    }
  }
</style>
