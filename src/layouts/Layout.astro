---
export interface Props {
  title: string;
}

const { title } = Astro.props;
import Navbar from "../components/Navbar.astro";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="William Carter Portfolio Homepage" />
    <meta name="author" content="William Carter" />
    <meta property="og:image" content="/thumbnail.webp" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/zfetch.png" as="image" fetchpriority="high" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
      window.localStorage.setItem("theme", theme);
      let currentTheme = localStorage.getItem("theme");
      if (currentTheme != null) {
        document.documentElement.setAttribute("data-theme", currentTheme);
        localStorage.setItem("theme", currentTheme);
      }
    </script>
  </head>

  <body class="bg-offw dark:bg-dark">
    <div class="site-header">
      <Navbar />
    </div>
    <slot />
  </body>
</html>

<style>
  :global(.site-header) {
    position: fixed;
    inset: 0 0 auto;
    z-index: 10;
  }

  :global(.site-navbar) {
    width: 100%;
    margin-inline: auto;
    background-color: rgb(255 255 255 / 38%);
    backdrop-filter: blur(4px);
  }

  :global(.dark .site-navbar) {
    background-color: rgb(32 32 35 / 50%);
  }

  @media (min-width: 700px) and (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: scroll()) {
      :global(.site-navbar) {
        animation: compact-navbar linear both;
        animation-timeline: scroll(root block);
        animation-range: 0 240px;
      }
    }
  }

  @keyframes compact-navbar {
    from {
      width: 100%;
      margin-top: 0;
      border-radius: 0;
      box-shadow: none;
    }

    to {
      width: min(94vw, 72rem);
      margin-top: 1rem;
      border-radius: 0.75rem;
      box-shadow:
        0 0.65rem 1.5rem rgb(0 0 0 / 12%),
        0 0.15rem 0.45rem rgb(0 0 0 / 8%);
    }
  }

  h3 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    text-align: center;
  }

  @media only screen and (max-width: 700px) {
    h3 {
      font-size: 1.5rem;
    }
  }
</style>
