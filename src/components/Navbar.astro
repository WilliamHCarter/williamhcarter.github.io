---
import MobileMenu from "../components/MobileMenu.jsx";
import Logo from "../components/Logo.astro";
import ThemeButton from "./ThemeButton.jsx";
import { profile } from "../data/profile";
import { sitePath } from "../lib/site-path";
---

<div class="site-navbar">
  <div class="flex justify-between items-center max-w-7xl mx-auto px-2 py-3 relative z-[1]">
    <Logo />
    <nav class="navlinks hidden pc:flex justify-end items-center gap-6 mr-[2vw]">
      <a
        class="text-dark dark:text-offw font-[500] hover:opacity-80 m-0"
        href={sitePath("/projects")}
      >
        Projects</a
      >
      <a
        class="text-dark dark:text-offw font-[500] hover:opacity-80 m-0"
        href={sitePath(profile.resume)}
      >
        Resume
      </a>
      <a
        class="text-dark dark:text-offw font-[500] hover:opacity-80 m-0"
        href={sitePath("/contact")}
      >
        Contact</a
      >
      <div
        class="px-4 py-2 bg-g hover:bg-ghl dark:hover:bg-[#ffffff25] dark:bg-[#ffffff14] rounded-md"
      >
        <a class="flex items-center" href={profile.github} aria-label="Github">
          <img
            class="inline-block w-4 mr-2 filter grayscale contrast-[8500] dark:invert"
            src={sitePath("/github.svg")}
            alt="gh-icon"
          />
          <p class="text-dark dark:text-offw text-base font-[500]">Github</p>
        </a>
      </div>
      <div class="w-10 h-10 bg-[#805ad5] dark:bg-[#f6ad54] rounded-md">
        <ThemeButton client:only="solid-js" />
      </div>
    </nav>
    <astro-fragment class="pc:hidden flex gap-4">
      <MobileMenu client:load />
      <div class="w-10 h-10 bg-[#805ad5] dark:bg-[#f6ad54] rounded-md">
        <ThemeButton client:only="solid-js" />
      </div>
    </astro-fragment>
  </div>
</div>
