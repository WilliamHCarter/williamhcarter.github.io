---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
  title: string;
  body: string;
  src: ImageMetadata;
  srcmobile: ImageMetadata;
  link: string;
  techStack: Array<{ alt: string; src: string }>;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
}

const { src, srcmobile, title, body, link, techStack, loading = "lazy", fetchpriority = "auto" } = Astro.props;
---

<div class="link-card flex p-1 mb-8">
  <a class="w-full no-underline leading-[1.4] flex flex-col" href={link}>
    <div class="thumbnail-container relative overflow-hidden rounded-md bg-[#dddddd]">
      <Image
        class="hidden pc:block img image object-cover w-full aspect-[16/10]"
        src={src}
        alt={title}
        loading={loading}
        fetchpriority={fetchpriority}
      />
      <Image
        class="pc:hidden img image object-cover w-full aspect-[16/10]"
        src={srcmobile}
        alt={title}
        loading={loading}
        fetchpriority={fetchpriority}
      />
      <div class="absolute bottom-0 right-0 scale-[1.4] -translate-x-[20%] flex align-center">
        {
          techStack.map(({ alt, src }) => (
            <div class="flex justify-center items-center ml-0.5 mb-2.5 mr-1.5">
              <embed src={src} class="embed rounded-sm h-5" />
            </div>
          ))
        }
      </div>
    </div>
    <h2 class="text-xl mt-4 mb-0 font-semibold opacity-95">
      {title}
    </h2>
    <p class="text-dark dark:text-offw mb-0 mr-[15%] opacity-50 font-medium">
      {body}
    </p>
  </a>
</div>

<style>
  .thumbnail-container {
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
  }

  .thumbnail-container:hover {
    transform: scale(1.01);
    box-shadow: 0 8px 12px rgba(0, 0, 0, 0.3);
  }
</style>
