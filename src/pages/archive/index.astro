---
import Layout from "../../layouts/Layout.astro";
import { archivedReleases } from "../../data/archive";
import { sitePath } from "../../lib/site-path";
---

<Layout title="Portfolio Archive | Will Carter">
  <main class="min-h-screen bg-offw text-dark dark:bg-dark dark:text-offw">
    <div class="container-lg max-w-5xl px-4 mx-auto pt-28 pb-20">
      <h1 class="text-4xl font-semibold tracking-tight">Archive</h1>
      <p class="mt-3 max-w-2xl text-lg opacity-65">
        Previous released iterations of this portfolio, preserved as they were at the time.
      </p>

      {
        archivedReleases.length === 0 ? (
          <p class="mt-12 text-lg opacity-50">No archived releases are available yet.</p>
        ) : (
          <div class="mt-12 grid grid-cols-1 grid:grid-cols-2 gap-4">
            {archivedReleases.map((release) => (
              <a
                class="rounded-md border border-g p-5 no-underline transition hover:scale-[1.01] dark:border-[#ffffff29]"
                href={sitePath(`/archive/${release.id}/`)}
              >
                <p class="m-0 text-sm font-medium uppercase tracking-wide opacity-50">
                  {release.releasedAt}
                </p>
                <h2 class="mt-2 mb-0 text-2xl font-semibold">{release.title}</h2>
                <p class="mb-0 mt-2 opacity-65">{release.description}</p>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </main>
</Layout>
